        "Room No", "Customer", "Type", "Days",
        "Check-In", "Check-Out",
        "Total", "Penalty", "Status"
    )

    history_tree = ttk.Treeview(
        win,
        columns=cols,
        show="headings"
    )

    for c in cols:
        history_tree.heading(c, text=c)
        history_tree.column(c, width=120, anchor="center")

    history_tree.pack(fill="both", expand=True)

    cursor.execute("""
        SELECT room, name, type, days,
               checkin, checkout,
               total, penalty, status
        FROM bookings
    """)

    for row in cursor.fetchall():
        history_tree.insert("", "end", values=row)

    ttk.Button(
        win,
        text="Export to Excel (CSV)",
        command=export_booking_history
    ).pack(pady=10)

