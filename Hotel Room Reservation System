import tkinter as tk
from tkinter import messagebox

# Room lists
standard_rooms = [f"S{str(i).zfill(2)}" for i in range(1, 51)]
deluxe_rooms = [f"D{str(i).zfill(2)}" for i in range(1, 31)]

# Store bookings (temporary)
booked_rooms = {}

# Check Availability
def check_availability():
    room_type = room_var.get()

    if room_type == "Standard":
        available = [r for r in standard_rooms if r not in booked_rooms]
    else:
        available = [r for r in deluxe_rooms if r not in booked_rooms]

    if available:
        messagebox.showinfo("Available Rooms", ", ".join(available[:10]) + " ...")
    else:
        messagebox.showerror("Full", "No rooms available!")

# Book Room
def book_room():
    name = entry_name.get()
    days = entry_days.get()
    room_type = room_var.get()
    room_number = entry_room.get().upper()

    if name == "" or days == "" or room_number == "":
        messagebox.showerror("Error", "Please fill all fields!")
        return

    try:
        days = int(days)
    except:
        messagebox.showerror("Error", "Days must be a number!")
        return

    # Validate room number
    if room_type == "Standard":
        if room_number not in standard_rooms:
            messagebox.showerror("Error", "Invalid Standard Room (S01-S50)")
            return
        price = 100
    else:
        if room_number not in deluxe_rooms:
            messagebox.showerror("Error", "Invalid Deluxe Room (D01-D30)")
            return
        price = 200

    # Check if already booked
    if room_number in booked_rooms:
        messagebox.showerror("Error", "Room already booked!")
        return

    total = price * days

    # Save booking
    booked_rooms[room_number] = {
        "name": name,
        "type": room_type,
        "days": days,
        "total": total
    }

    # Receipt Output
    result = f"""
======= HOTEL RECEIPT =======
Customer Name : {name}
Room Type     : {room_type}
Room Number   : {room_number}
Booked for    : {days} Days
Total Payment : RM {total}
============================
"""

    messagebox.showinfo("Booking Confirmed", result)

# Search Room
def search_room():
    room_number = entry_search.get().upper()

    if room_number in booked_rooms:
        data = booked_rooms[room_number]

        result = f"""
======= RECORD FOUND =======
Customer Name : {data['name']}
Room Type     : {data['type']}
Room Number   : {room_number}
Days          : {data['days']}
Total         : RM {data['total']}
============================
"""
        messagebox.showinfo("Result", result)
    else:
        messagebox.showerror("Not Found", "Room not found!")

# GUI
root = tk.Tk()
root.title("Hotel Reservation System")
root.geometry("400x450")

tk.Label(root, text="Customer Name").pack()
entry_name = tk.Entry(root)
entry_name.pack()

tk.Label(root, text="Room Type").pack()
room_var = tk.StringVar(value="Standard")
tk.OptionMenu(root, room_var, "Standard", "Deluxe").pack()

tk.Label(root, text="Room Number (e.g. S01 / D01)").pack()
entry_room = tk.Entry(root)
entry_room.pack()

tk.Label(root, text="Number of Days").pack()
entry_days = tk.Entry(root)
entry_days.pack()

tk.Button(root, text="Check Availability", command=check_availability).pack(pady=5)
tk.Button(root, text="Book Room", command=book_room).pack(pady=5)

tk.Label(root, text="Search by Room Number").pack()
entry_search = tk.Entry(root)
entry_search.pack()

tk.Button(root, text="Search Record", command=search_room).pack(pady=5)

root.mainloop()
